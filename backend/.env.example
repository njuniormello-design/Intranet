# Copie este arquivo para .env e configure com suas preferências

# ==================== DATABASE ====================
# Configurações do MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=intranet_db
DB_PORT=3306

# ==================== JWT ====================
# Configurações de autenticação
# IMPORTANTE: Mude JWT_SECRET em produção para um valor aleatório!
JWT_SECRET=seu_secreto_jwt_super_seguro_aqui_2024
JWT_EXPIRE=7d

# ==================== SERVIDOR ====================
# Porta e modo de execução
PORT=5000
NODE_ENV=development

# ==================== UPLOAD ====================
# Configurações de envio de arquivos
UPLOAD_DIR=uploads/
MAX_FILE_SIZE=5242880

# ==================== OPTIONAL ====================
# Deixe comentado se não usar
# EMAIL_HOST=smtp.gmail.com
# EMAIL_USER=seu_email@gmail.com
# EMAIL_PASS=sua_senha_app
